# Living Heirloom server configuration. Copy to .env and adjust.

# Port for the API server (and the whole app under `npm run start`).
PORT=3001

# --- Letter drafting (any OpenAI-compatible server: Ollama, LM Studio, vLLM) ---
OPENAI_BASE_URL=http://localhost:11434/v1
# API key if your model server requires one (Ollama does not).
OPENAI_API_KEY=
# Model name as known to your model server.
MODEL=llama3.1

# --- Delivery (sealed letters emailed on their unlock date) ---
# Required for delivery. Generate with:  openssl rand -base64 32
#   (PowerShell: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
LH_ENCRYPTION_KEY=
# Public URL of the app, used to build the private view links in emails.
APP_BASE_URL=http://localhost:3001
# SMTP settings. Leave unset in development: delivery then writes .eml files
# to server/data/outbox/ instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Living Heirloom <letters@example.com>"

# --- Voice (see docs/voice.md) ---
# kokoro (local, default) | chatterbox | elevenlabs | none
TTS_PROVIDER=kokoro
# Kokoro quantization: fp32 | fp16 | q8 (default) | q4 | q4f16
KOKORO_DTYPE=q8
# Only for TTS_PROVIDER=elevenlabs:
ELEVENLABS_API_KEY=
# Only for TTS_PROVIDER=chatterbox (see server/voice/sidecar/):
CHATTERBOX_URL=http://localhost:8004
